# 資料庫
DATABASE_URL="postgresql://user:password@localhost:5432/travel_db"

# NextAuth.js（必填）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # 用這個指令產生：openssl rand -base64 32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LINE Login
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# Cloudinary（圖片上傳）
# 到 https://cloudinary.com 免費註冊後，在 Dashboard 取得這三個值
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 前端 API URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api
